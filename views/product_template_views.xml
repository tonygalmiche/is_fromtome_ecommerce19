<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_inherit_colisage" model="ir.ui.view">
        <field name="name">product.template.form.inherit.colisage</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="invoice_policy" position="after">
                <field name="is_colisage"/>
                <field name="is_nb_pieces_par_colis"/>
                <field name="is_poids_net_colis"/>
            </field>
        </field>
    </record>

    <record id="product_template_tree_inherit_colisage" model="ir.ui.view">
        <field name="name">product.template.tree.inherit.colisage</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="after">
                <field name="is_colisage" optional="show"/>
                <field name="is_nb_pieces_par_colis" optional="show"/>
                <field name="is_poids_net_colis" optional="show"/>
            </field>
        </field>
    </record>

</odoo>
